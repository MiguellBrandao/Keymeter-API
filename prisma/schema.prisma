// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/common/prisma/generated"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id String @id @default(uuid())

  name String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships MemberShip[]
  apiKeys     ApiKey[]
  events      Event[]

  @@index([name])
}

model User {
  id String @id @default(uuid())

  email    String
  password String

  name String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships MemberShip[]
  apiKeys     ApiKey[]

  @@unique([email])
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model MemberShip {
  id String @id @default(uuid())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role Role @default(MEMBER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, userId])
  @@index([tenantId, role])
}

model ApiKey {
  id String @id @default(uuid())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name   String
  scopes String[]

  keyPrefix String
  keyHash   String

  revokedAt  DateTime?
  lastUsedAt DateTime?

  createByUserId String
  createdByUser  User   @relation(fields: [createByUserId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events Event[]

  @@index([tenantId, createdAt])
  @@index([tenantId, revokedAt])
}

enum EventType {
  TRACK
  IDENTIFY
  PAGE
  CUSTOM
}

model Event {
  id String @id @default(uuid())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  apiKeyId String
  apiKey   ApiKey @relation(fields: [apiKeyId], references: [id])

  type EventType @default(CUSTOM)

  name String?

  properties Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/common/prisma/generated"
}

datasource db {
  provider = "postgresql"
}

model Org {
  id String @id @default(uuid())

  name String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships MemberShip[]
  apiKeys     ApiKey[]
  events      Event[]
  invites     Invite[]

  @@index([name])
}

model User {
  id String @id @default(uuid())

  email    String
  password String

  name String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships MemberShip[]
  apiKeys     ApiKey[]

  createdInvites Invite[] @relation("InvitesCreatedBy")
  revokedInvites Invite[] @relation("InvitesRevokedBy")
  orgInvites     Invite[]

  @@unique([email])
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model MemberShip {
  id String @id @default(uuid())

  orgId String
  org   Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role Role @default(MEMBER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, userId])
  @@index([orgId, role])
}

model Invite {
  id String @id @default(uuid())

  orgId String
  org   Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role Role @default(MEMBER)

  tokenHash String @unique

  createdByUserId  String
  createdBy User  @relation("InvitesCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)

  acceptedAt       DateTime?

  revokedAt       DateTime?
  revokedByUserId String?
  revokedBy User? @relation("InvitesRevokedBy", fields: [revokedByUserId], references: [id], onDelete: SetNull)

  createdAt        DateTime  @default(now())
}

model ApiKey {
  id String @id @default(uuid())

  orgId String
  org   Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)

  name   String
  scopes String[]

  keyPrefix String
  keyHash   String

  revokedAt  DateTime?
  lastUsedAt DateTime?

  createByUserId String
  createdByUser  User   @relation(fields: [createByUserId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events Event[]

  @@unique([keyPrefix])
  @@index([orgId, createdAt])
  @@index([orgId, revokedAt])
}

enum EventType {
  TRACK
  IDENTIFY
  PAGE
  CUSTOM
}

model Event {
  id String @id @default(uuid())

  orgId String
  org   Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)

  apiKeyId String
  apiKey   ApiKey @relation(fields: [apiKeyId], references: [id])

  type EventType @default(CUSTOM)

  properties Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AuditAction {
  ORG_CREATED

  INVITE_CREATED
  INVITE_REVOKED

  MEMBER_ADDED
  MEMBER_REMOVED
  MEMBER_ROLE_CHANGED

  API_KEY_CREATED
  API_KEY_REVOKED
  API_KEY_ROTATED
}

enum AuditActorType {
  USER
  SYSTEM
}

enum AuditTargetType {
  org
  invite
  member
  api_key
}

model AuditLog {
  id String @id @default(uuid())

  orgId  String
  action AuditAction

  actorUserId String?
  actorType   AuditActorType @default(USER)

  targetType AuditTargetType?
  targetId   String?

  ip        String?
  userAgent String?

  metadata  Json?
  createdAt DateTime @default(now())

  @@index([orgId, createdAt])
  @@index([orgId, action, createdAt])
  @@index([orgId, targetType, targetId])
}

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/keymeter?schema=public"

# Auth
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# Redis
REDIS_URL="redis://localhost:6379"

# Rate limit
RATE_LIMIT_EVENTS_PER_HOUR=100
RATE_LIMIT_FAIL_OPEN=true

# App
PORT=3000

